# Server
NODE_ENV=development
PORT=3000
CLIENT_URL=http://localhost:5173

# PostgreSQL
POSTGRES_DB=nutricoach
POSTGRES_USER=nutricoach_user
POSTGRES_PASSWORD=change_me
DATABASE_URL=postgres://nutricoach_user:change_me@localhost:5432/nutricoach

# pgAdmin
PGADMIN_DEFAULT_EMAIL=admin@nutricoach.local
PGADMIN_DEFAULT_PASSWORD=change_me

# MongoDB IA
MONGO_INITDB_ROOT_USERNAME=nutricoach_ai
MONGO_INITDB_ROOT_PASSWORD=change_me
MONGO_DB=nutricoach_ai
MONGO_URI=mongodb://nutricoach_ai:change_me@localhost:27017/nutricoach_ai?authSource=admin

# Auth
JWT_SECRET=replace_with_a_long_secure_random_string
GOOGLE_CLIENT_ID=replace_with_google_client_id

# Gemini IA
GEMINI_API_KEY=replace_with_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TEMPERATURE=0.4
GEMINI_MAX_OUTPUT_TOKENS=1024

# AI Provider Router
# AI_TEXT_PROVIDER selects the primary text provider: 'gemini' (default) or 'deepseek'
# AI_ENABLE_DEEPSEEK must also be 'true' to activate DeepSeek; Gemini is always the fallback
AI_TEXT_PROVIDER=gemini
AI_TEXT_FALLBACK_PROVIDER=gemini
AI_ENABLE_DEEPSEEK=false

# DeepSeek IA (text-only — not active by default)
DEEPSEEK_API_KEY=replace_with_deepseek_api_key
DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_BASE_URL=https://api.deepseek.com   # override only for proxy / self-hosted
# DEEPSEEK_TEMPERATURE=0.4
# DEEPSEEK_MAX_OUTPUT_TOKENS=1024
