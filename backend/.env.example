# ── Servidor ──
PORT=3000
NODE_ENV=development

# ── Base de datos PostgreSQL ──
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nutricoach_db
DB_USER=postgres
DB_PASSWORD=postgres

# ── Seguridad ──
JWT_SECRET=cambia_esto_por_un_secreto_largo_y_aleatorio
SESSION_SECRET=otro_secreto_distinto_y_largo_para_sesiones

# ── pgAdmin (docker-compose) ──
PGADMIN_DEFAULT_EMAIL=admin@nutricoach.com
PGADMIN_DEFAULT_PASSWORD=admin