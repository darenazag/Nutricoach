{
  "name": "nutricoach-backend",
  "version": "1.0.0",
  "description": "Backend MVC para NutriCoach: gestion de perfiles, comidas y alimentos con integracion de Open Food Facts y TheMealDB",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "build": "tsc && npm run copy:assets",
    "copy:assets": "node --input-type=module -e \"import {copyFileSync} from 'fs'; copyFileSync('src/scripts/schema.sql','dist/scripts/schema.sql')\"",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "db:init": "tsx src/scripts/initDb.ts",
    "db:seed": "tsx src/scripts/seedFromApis.ts",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "nutrition",
    "open-food-facts",
    "themealdb",
    "express",
    "typescript",
    "postgres",
    "mvc"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.10",
    "@types/pg": "^8.11.6",
    "tsx": "^4.19.2",
    "typescript": "^5.5.3"
  }
}
