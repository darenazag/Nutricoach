{
  "name": "nutricoach-backend",
  "version": "1.0.0",
  "description": "Backend NutriCoach: PostgreSQL P0 + módulo IA (Mongo, Gemini, DeepSeek)",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "build": "tsc && npm run copy:assets",
    "copy:assets": "node --input-type=module -e \"import {copyFileSync} from 'fs'; copyFileSync('src/scripts/schema.sql','dist/scripts/schema.sql')\"",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "db:init": "tsx src/scripts/initDb.ts",
    "db:seed": "tsx src/scripts/seedFromApis.ts",
    "lint": "tsc --noEmit",
    "check": "tsc --noEmit",
    "seed:ai-prompts": "tsx src/modules/ai/seeders/seedAiPromptTemplates.ts",
    "test": "vitest run"
  },
  "keywords": [
    "nutrition",
    "open-food-facts",
    "themealdb",
    "express",
    "typescript",
    "postgres",
    "mvc"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@google/genai": "^2.4.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.6.2",
    "multer": "^2.1.1",
    "pg": "^8.21.0",
    "sharp": "^0.34.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.9.0",
    "@types/pg": "^8.11.6",
    "mongodb-memory-server": "^11.1.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
